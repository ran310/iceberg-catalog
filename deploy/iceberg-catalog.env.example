# Copy to /etc/iceberg-catalog.env on the instance (CodeDeploy does this from your bundle).
# GitHub Actions overwrites this from iceberg-catalog.env.example + repo variable CATALOG_WAREHOUSE.
# Replace MY_LAKE_BUCKET and region. EC2 instance profile supplies AWS credentials (no static keys).
#
# nginx Basic auth: GitHub secret ICEBERG_CATALOG_HTPASSWD → deploy/iceberg-catalog.htpasswd in CI only (gitignored).

AWS_REGION=us-east-1

# JdbcCatalog: durable SQLite on EBS (bind-mount /var/lib/iceberg-catalog in systemd unit).
CATALOG_URI=jdbc:sqlite:file:/data/catalog.db
CATALOG_JDBC_USER=user
CATALOG_JDBC_PASSWORD=password
CATALOG_JDBC_DRIVER=org.sqlite.JDBC

# Default warehouse for new tables (Iceberg data + metadata under this prefix).
CATALOG_WAREHOUSE=s3://MY_LAKE_BUCKET/warehouse/

# S3 file IO (uses default AWS credential chain on the host / in the container).
CATALOG_IO__IMPL=org.apache.iceberg.aws.s3.S3FileIO

REST_PORT=9000
